# Scalable RAG — environment configuration template.
#
# Copy to `.env` (which IS gitignored) and fill in values.
# No real credentials should ever live in this file.

# ===== LLM providers — set at least one =====
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Active provider: groq | gemini | openai
DEFAULT_PROVIDER=groq

# ===== Pipeline settings =====
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=rag_collection
QDRANT_PREFER_GRPC=false

EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_MODEL_LOCAL_PATH=models/bge-base-en-v1.5
USE_ONNX_EMBEDDINGS=true

# Disable unless you have the model files in models/bge-reranker-base/.
RERANKER_ENABLED=false
RERANKER_MODEL_PATH=models/bge-reranker-base

CACHE_ENABLED=true
CACHE_STRATEGY=exact

REDIS_ENV=local
REDIS_URL=redis://redis:6379/0

# Keep DEBUG=false so QdrantStore uses the qdrant container, not in-memory.
DEBUG=false
LOG_LEVEL=INFO

# ===== Postgres =====
# These three are required. docker-compose reads them to provision the
# postgres container AND to build BACKEND_DATABASE_URL automatically.
# For bare-metal runs (no compose), set BACKEND_DATABASE_URL yourself.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=rag

# Only needed when running uvicorn outside docker-compose. Format:
#   postgresql+asyncpg://<user>:<pass>@<host>:5432/<db>
BACKEND_DATABASE_URL=

# ===== Backend =====
BACKEND_API_KEY_PREFIX=rag_

# Required for the very first POST /v1/auth/keys call. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Unset (or rotate) after issuing your admin key.
BACKEND_BOOTSTRAP_TOKEN=

# Pipe-separated "name:description" pairs the agent planner uses for routing.
BACKEND_COLLECTIONS_REGISTRY=

# Wide-open for local dev; tighten in production.
BACKEND_CORS_ORIGINS=*

BACKEND_MAX_UPLOAD_SIZE_MB=50
BACKEND_INGEST_TEMP_DIR=/app/data/uploads
BACKEND_MAX_CONCURRENT_SUBQUERIES=3
BACKEND_LOG_REQUESTS=true
